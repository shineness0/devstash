# Database (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
# Use the dev branch URL for DATABASE_URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth v5
AUTH_SECRET=""  # Generate with: openssl rand -base64 32
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Resend (email)
# Get your API key from https://resend.com
RESEND_API_KEY=""

# Email verification on register
# Set to "true" to require email verification before sign-in (recommended for production)
# Set to "false" (or leave unset) to skip verification — useful in dev when no domain is configured
REQUIRE_EMAIL_VERIFICATION="false"

# Upstash Redis (rate limiting)
# Create a Redis instance at https://console.upstash.com and copy the REST URL and token
# If not set, rate limiting is disabled (fail open) — safe for local dev
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
